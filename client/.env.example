# Supabase Configuration
# Hämta dessa från din Supabase dashboard: https://app.supabase.com/project/_/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Notera: Service role key ska INTE finnas i frontend!
# Den används endast i Edge Functions

# ============================================
# Error Monitoring (Sentry)
# ============================================
# Skapa konto på https://sentry.io och skapa ett React-projekt
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# VITE_SENTRY_DEBUG=false

# App version (för Sentry releases)
# VITE_APP_VERSION=1.0.0

# ============================================
# AI Configuration (Vercel All-in-One)
# ============================================
# 
# Ingen AI_API_URL behövs längre! 
# AI-funktionerna körs nu som Vercel Serverless Functions på samma domän.
# 
# Miljövariabler för AI (OpenRouter) sätts i Vercel Dashboard istället:
# - OPENROUTER_API_KEY=sk-or-v1-...
# - AI_MODEL=anthropic/claude-3.5-sonnet (valfritt)
# - SITE_URL=https://dindomän.se (valfritt)
#
# Gå till: https://vercel.com/dashboard → ditt projekt → Settings → Environment Variables

# ============================================
# Rate Limiting (Upstash Redis)
# ============================================
# Krävs för produktion! Skapa gratis konto på https://upstash.com
# Skapa en ny Redis-databas och kopiera REST-uppgifterna
#
# Lägg till i Vercel Dashboard → Settings → Environment Variables:
# - UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# - UPSTASH_REDIS_REST_TOKEN=xxx
#
# Utan Redis fungerar inte rate limiting i serverless!
